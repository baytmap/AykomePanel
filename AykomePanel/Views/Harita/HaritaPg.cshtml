@using System.Security.Claims

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AykomePanel</title>
    <link href='https://unpkg.com/boxicons@2.0.7/css/boxicons.min.css' rel='stylesheet'>

    <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/leaflet.css" />
    <link rel="stylesheet" href="~/css/leafletdraw.css" />
    <link rel="stylesheet" href="~/css/haritacss.css" asp-append-version="true" />
</head>
<body class="">
    <div class="katmLan">
        <div class="katmanPnl">
            <div class="logo-details">
                <img src="/img/konya_büyükşehir_belediyesi_logosu.png">
            </div>

            <div class="text-center">
                <a asp-controller="Home" asp-action="Panel" class="btn btn-primary btn-mini p-2"><i class="bx bx-grid-alt bi bi-search"></i>Dashboard Sayfası</a>
            </div>
            <div id="dvkat">
                <ul>
                    <li>
                        <div class="fdsf">
                            Aykome
                            <div class="fvd">
                                <div class="altbas">Günlük Kazılar</div>
                                <div class="sbbhd1">
                                    <div class="rns" style="background-color: #159c5f; width: 13px; height: 13px; border-radius: 10px;"></div>
                                    <input class="form-check-input chbKatOnOf1" checked="checked" data-tip="1" data-renkkodu="#159c5f" type="checkbox">
                                    <a class="btnKtmnShow">Aktif Kazılar</a>
                                </div>
                                <div class="sbbhd1">
                                    <div class="rns" style="background-color:#fed300; width: 12px; height: 12px; border-radius: 10px;"></div>
                                    <input class="form-check-input chbKatOnOf1"  data-tip="2" data-renkkodu="#fed300" type="checkbox">
                                    <a class="btnKtmnShow">Biten Kazılar</a>
                                </div>
                                <div class="sbbhd1">
                                    <div class="rns" style="background-color:#a8a8a8; width: 11px; height: 11px; border-radius: 10px;"></div>
                                    <input class="form-check-input chbKatOnOf1"  data-tip="0" data-renkkodu="#a8a8a8" type="checkbox">
                                    <a class="btnKtmnShow">Pasif Kazılar</a>
                                </div>

                                <div class="sbbhd1">
                                    <div class="rns" style="background-color:#2779b6; width: 11px; height: 11px; border-radius: 10px;"></div>
                                    <input class="form-check-input chbKatOnOf1"  data-tip="3" data-renkkodu="#2779b6" type="checkbox">
                                    <a class="btnKtmnShow">Başlanmayan Kazılar</a>
                                </div>
                            </div>
                        </div>
                    </li>
                </ul>

                <ul>
                    <li>
                        <div class="fdsf">
                            <div class="fvd">
                                <div class="altbas">Kaçak Kazılar</div>
                                <div class="sbbhd1">
                                    <div class="rns" style="background-color:brown; width: 13px; height: 13px; border-radius: 10px;"></div>
                                    <input class="form-check-input chbKatOnOf1" data-tip="4" data-renkkodu="brown" type="checkbox">
                                    <a class="btnKtmnShow">Kaçak Kazı</a>
                                </div><div></div>
                            </div>
                        </div>
                    </li>
                </ul>

                <hr />
                <div class="altbas">
                    <input class="form-check-input chbfF" type="checkbox">
                    KATMANLAR
                    <div class="btn-group dropup">
                        <button type="button" class="btn btn-sm" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class='bx bx-dots-vertical-rounded'></i>
                        </button>
                        <div class="dropdown-menu">
                            <div class="p-2">
                                <div class="fs-mini">Opaklık Değeri</div>
                                <input type="range" min="0" max="1" step="0.1" value="1" class="slider" id="rngOpak">
                            </div>
                        </div>
                    </div>


                    <a class="kataacsall" data-open="1"><span class="bx bx-chevron-up"></span></a>
                </div>
                <ul id="lstKatman">
                </ul>
            </div>
        </div>
        <div class="map">
            <div class="home-content">
                <div class="d-flex gap-2">
                    <div class="grps">
                        <span class="hnde">Yaklaş</span>
                        <button id="btn-zm1" type="button" title="Harita'da Yaklaş" class="bttn"><i class='bx bx-plus'></i></button>
                        <button id="btn-zm2" type="button" title="Harita'da Uzaklaş" class="bttn"><i class='bx bx-minus'></i></button>
                    </div>
                    <div class="ayrc"></div>
                    <div class="grps">
                        <span class="hnde">Çizim</span>
                        <div id="custom-buttons" class="d-flex gap-1">
                            <div id="draw-polyline" title="Polyline Çiz" class="csb custom-button"><i class='bx bx-trending-down'></i></div>
                            <button id="btn-linset" type="button" title="Polyline Stili" class="bttn"><i class='bx bx-cog'></i></button>
                        </div>
                    </div>

                    <div class="ayrc"></div>
                    <div class="grps">
                        <span class="hnde">Araçlar</span>
                        <button id="btn-info" type="button" class="bttn btna" data-mod="1"><i class='bx bx-info-square'></i></button>
                        <button id="btn-zm2" type="button" data-ref="#mdlKoordinatAra" data-temizle="false" class="bttn opnModal" title="Kordinata Git"><i class='bx bx-search-alt-2'></i></button>
                        <button id="btn-modd" type="button" class="bttn btna" data-mod="1"><i class='bx bx-palette'></i><span>Koyu Mod</span></button>
                        <button id="btn-cd3" type="button" data-ref="#mdlYolAra" data-temizle="false" class="bttn btna opnModal" title="Kordinata Git"><i class='bx bx-search-alt-2'></i>Cadde Ara</button>
                        <button id="btn-edtip" type="button" class="bttn btna" hidden="hidden" title="Düzeltme Modundan Çık"><i class='bx bx-x'></i>Düzeltme Modundan Çık</button>
                    </div>
                    <div class="ayrc"></div>
                    <div class="grps">
                        <span class="hnde">Yükleme</span>
                        <div class="flsa">
                            <div class="vwi"><i class='bx bx-upload'></i><span>DXF Yükle</span></div>
                            <input type="file" class="ffile" id="flinput" accept=".dxf">
                        </div>
                        <div class="flsa">
                            <div class="vwi"><i class='bx bx-upload'></i><span>KML Yükle</span></div>
                            <input type="file" class="ffile" id="flinputkml" accept=".kml">
                        </div>
                        @*  <div class="flsa">
                        <div class="vwi"><i class='bx bx-upload'></i><span>Netcat Yükle</span></div>
                        <input type="file" class="ffile" id="fileInputNtc" accept=".ncz">
                        </div> *@
                    </div>
                </div>

                <div class="ms-md-auto">
                    <div class="dropdown-center pe-4">
                        <div class="dropdown-toggle d-flex align-items-center" data-bs-toggle="dropdown" aria-expanded="false">
                            @if (User.Identity.IsAuthenticated && User.Claims.FirstOrDefault(c => c.Type == "UserName") != null)
                            {
                                @if (User.Claims.FirstOrDefault(c => c.Type == "UserPhoto") != null)
                                {
                                    <img id="imgPer" src="@User.Claims.FirstOrDefault(c => c.Type == "UserPhoto").Value" />
                                }
                                @*   *@
                                <div>
                                    <div> <span class="kkrm4" id="kkrm4">@User.Claims.FirstOrDefault(c => c.Type == "UserName").Value</span></div>
                                    <div class="gbt56">
                                        <span class="kkrm1">@User.Claims.FirstOrDefault(c => c.Type == "Kurum").Value</span>/
                                        <span class="kkrm3">@User.Claims.FirstOrDefault(c => c.Type == "Birim").Value</span>
                                    </div>
                                    <div class="gbt56"> <span class="kkrm2">@User.Claims.FirstOrDefault(c => c.Type == "BirimUstGrupAd").Value</span></div>
                                </div>
                            }
                        </div>
                        <ul class="dropdown-menu" style="z-index: 10000;">
                            <li><a class="dropdown-item" asp-controller="Genel" asp-action="SifreDegistir">Şifre Değiştir</a></li>
                            <li><a asp-controller="Home" asp-action="GuvenliCikis" class="dropdown-item">Çıkış Yap</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div id="map"></div>
            <div class="lblKoordinat">
                <span>Enlem:</span>
                <div id="lblEnl" class="lblw"></div>
                <span>Boylam:</span>
                <div id="lblByl" class="lblw"></div>
            </div>
        </div>
    </div>

    <div class="modal" id="mdlVeri" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="mdlBaslik">Proje</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" style="font-size: 9px;"></button>
                    <button type="button" class="btn btn-full" style="font-size: 11px; color: #5c5c5c;">
                        <i class='bx bx-fullscreen'></i>
                    </button>
                </div>
                <div class="modal-body">
                    <ul class="nav nav-pills mb-3" id="pills-tab" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="pnlPrj-1-tab" data-bs-toggle="pill" data-bs-target="#pnlPrj-1" type="button" role="tab" aria-controls="pnlPrj-1" aria-selected="true">Proje Bilgileri</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="pnlPrj-2-tab" data-bs-toggle="pill" data-bs-target="#pnlPrj-2" type="button" role="tab" aria-controls="pnlPrj-2" aria-selected="false">İş Detayı</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="pnlPrj-3-tab" data-bs-toggle="pill" data-bs-target="#pnlPrj-3" type="button" role="tab" aria-controls="pnlPrj-3" aria-selected="false">Dosya</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="pnlPrj-4-tab" data-bs-toggle="pill" data-bs-target="#pnlPrj-4" type="button" role="tab" aria-controls="pnlPrj-4" aria-selected="false">Dağıtım</button>
                        </li>
                    </ul>

                    <div class="tab-content" id="pills-tabContent">
                        <div class="tab-pane fade show active" id="pnlPrj-1" role="tabpanel" aria-labelledby="pnlPrj-1-tab" tabindex="0">
                            <div class="row">
                                <div class="col-8">
                                    <h2 class="altbaslik">Proje</h2>
                                    <div class="row">
                                        <div class="col-4">
                                            <div class="bcol2">
                                                <div class="lblDiv">
                                                    <div class="lbll">Proje No</div>
                                                </div>
                                                <div class="ltxt">
                                                    <input id="txtPrjNo" type="text" class="form-control form-control-sm" readonly="readonly" />
                                                </div>
                                            </div>

                                        </div>
                                        <div class="col-4">
                                            <div class="bcol2">
                                                <div class="lblDiv">
                                                    <div class="lbll">Talep Tarihi</div>
                                                </div>
                                                <div class="ltxt">
                                                    <input id="txtPrjTalepTarihi" data-validate-hint="Zorunlu Alan!" data-validate-func="required" type="datetime-local" class="form-control form-control-sm" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="bcol2">
                                                <div class="lblDiv">
                                                    <div class="lbll">Proje Tipi</div>
                                                </div>
                                                <div class="ltxt">
                                                    <select class="form-select form-select-sm" id="txtPrjTipi" data-validate-hint="Zorunlu Alan!" data-validate-func="selectbox"><option value="-1"></option></select>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="bcol2">
                                        <div class="lblDiv">
                                            <div class="lbll">Proje Amacı</div>
                                        </div>
                                        <div class="ltxt">
                                            <textarea class="form-control form-control-sm" data-validate-hint="Zorunlu Alan!" data-validate-func="required" id="txtPrjAmaci"></textarea>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <h2 class="altbaslik">Planlanan</h2>
                                    <div class="bcoll">
                                        <div class="lblDiv">
                                            <div class="lbll">Başlama Tarihi</div>
                                        </div>
                                        <div class="ltxt">
                                            <input type="date" class="form-control form-control-sm" id="txtPrjBasTarihi" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                                        </div>
                                    </div>

                                    <div class="bcoll mt-1">
                                        <div class="lblDiv">
                                            <div class="lbll">Bitiş Tarihi</div>
                                        </div>
                                        <div class="ltxt">
                                            <input type="date" class="form-control form-control-sm" id="txtPrjBitTarihi" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <h2 class="altbaslik mt-3">Proje Başvuru Bilgileri</h2>
                            <div class="row">
                                <div class="col">
                                    <div class="bcol2">
                                        <div class="lblDiv">
                                            <div class="lbll">Vatandaşın Başvuru Tarihi</div>
                                        </div>
                                        <div class="ltxt">
                                            <input type="date" class="form-control form-control-sm" id="txtPrjVatBasTar" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                                        </div>
                                    </div>

                                    <div class="bcol2">
                                        <div class="lblDiv">
                                            <div class="lbll">Dilekçe No</div>
                                        </div>
                                        <div class="ltxt">
                                            <input type="text" class="form-control form-control-sm" id="txtPrjDilekcNo" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="row" id="pnltcKapiNo" hidden="hidden">
                                        <div class="col">
                                            <div class="bcol2">
                                                <div class="lblDiv">
                                                    <div class="lbll">T.C. No</div>
                                                </div>
                                                <div class="ltxt">
                                                    <input type="text" class="form-control form-control-sm" id="txtPrjTcNo" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col">
                                            <div class="bcol2">
                                                <div class="lblDiv">
                                                    <div class="lbll">Kapı No</div>
                                                </div>
                                                <div class="ltxt">
                                                    <input type="text" class="form-control form-control-sm" id="txtPrjKapiNo" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="bcol2">
                                        <div class="lblDiv">
                                            <div class="lbll">İlgili Kişi</div>
                                        </div>
                                        <div class="ltxt">
                                            <input type="text" class="form-control form-control-sm" id="txtPrjIlgKisi" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                                        </div>
                                    </div>

                                    <div class="bcol2">
                                        <div class="lblDiv">
                                            <div class="lbll">Başvuru Yapan</div>
                                        </div>
                                        <div class="ltxt">
                                            <input type="text" class="form-control form-control-sm" id="txtPrjBasYapn" readonly="readonly" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                                        </div>
                                    </div>



                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="pnlPrj-2" role="tabpanel" aria-labelledby="pnlPrj-2-tab" tabindex="0">
                            <div id="domisDetay">
                            </div>

                        </div>
                        <div class="tab-pane fade" id="pnlPrj-3" role="tabpanel" aria-labelledby="pnlPrj-3-tab" tabindex="0">
                            <div>
                                <div class="ffeer5 d-flex gap-1">
                                </div>
                                <div class="mt-3">
                                    <input class="form-control form-control-sm" id="filMusteriFotograf" type="file">
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="pnlPrj-4" role="tabpanel" aria-labelledby="pnlPrj-4-tab" tabindex="0">
                            <h3 class="baslik">Birimler</h3>
                            <div id="lstBirimler"></div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger " data-bs-dismiss="modal">
                        <span class="ph ph-plus  me-1"></span>
                        İptal
                    </button>
                    <button type="button" id="btnInsert" class="btn btn-primary">
                        <span class="ph ph-checks me-1"></span>
                        Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="mdlCizSil" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Silme İşlemi</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" style="font-size: 12px;" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div>Bu Çizim Silinsin mi?</div>
                </div>
                <div class="modal-footer">
                    <button type="button" onclick="fncCizimiSilSon()" class="btn btn-success btn-sm">
                        <i class='bx bx-check'></i>
                        <span>Sil</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="toast-container position-fixed p-3 start-50 translate-middle-x" style="top: 25px;">
        <div id="liveToast" class="toast align-items-center" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex  align-items-center ps-2">
                <i class="bi bi-search"></i>
                <div class="toast-body" id="toastmes">
                </div>
                <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <div class="modal fade" id="mdlKatmanFtr" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="mdlKatmanBaslik"></h5>
                    <button type="button" class="btn-close" placeholder="+" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="mdlKatmanBoody">
                </div>
            </div>
        </div>
    </div>

    <div class="dmodal" id="mdlMenu">
        <ul>
            <li>
                <a id="mnYakinlas">Yakınlaş</a>
            </li>
            <li>
                <a id="mnUzaklas">Uzaklaş</a>
            </li>
            <li>
                <a id="mnSecNesYakinlas">Seçili Nesneye Yakınlas</a>
            </li>
            <li>
                <a id="mnKoordinaTblg">Koordinat Bilgisi</a>
            </li>
            <li>
                <a id="mnKatmnStili">Katman Sitili</a>
            </li>
            <li>
                <a id="mnsnp1">Snap Hassasiyeti</a>
            </li>
            <li class="position-relative">
                <a id="mnAykome">Aykome <i class='bx bx-chevron-right float-end'></i></a>
                <ul class="altmmnul">
                    @* <li><a id="mnalt1" onclick='zxc("#mdlMenu").sakla();fncModalAc("#mdlVeri");'>Proje Başvurusu</a> </li> *@
                    <li><a id="mnalt1" onclick=' zxc("#mdlMenu").sakla();fncModalAc("#mdlImza");imzaRefModal = "#mdlVeri";'>Proje Başvurusu</a> </li>
                    @*    <li><a id="mnalt2">Proje Bilgisi Göster</a> </li>
                    <li><a id="mnalt3">Proje Ekle</a> </li> *@
                </ul>
            </li>
            <li>
                <a id="mnAbs">ABS</a>
            </li>
            <li>
                <a id="mnAltYapı">AltYapı</a>
            </li>
            <li>
                <a id="mnUkome">Ukome</a>
            </li>
        </ul>

    </div>


    <div class="modal" id="mdlSonuc" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Projeniz</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" style="font-size: 12px;" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div>Projeniz Oluşturuldu, <a asp-controller="Aykome" asp-action="ProjeListesi" class="btn btn-link p-0 fw-bold">Proje Listesine</a> Gitmek İster misin?</div>
                </div>
            </div>
        </div>
    </div>


    <div class="modal fade" id="cfmodal" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalLabel">Çizgi Özellikleri</h5>
                    <button type="button" class="btn-close" placeholder="+" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form>

                        <div class="form-group">
                            <label for="color">Renk:</label>
                            <input type="color" class="form-control" id="txtcolor">
                        </div>
                        <div class="form-group">
                            <label for="weight">Kalınlık:</label>
                            <input type="number" class="form-control" id="txtweight">
                        </div>
                        <div class="form-group">
                            <label for="opacity">Saydamlık:</label>
                            <input type="number" class="form-control" id="txtopacity" min="0" max="1" step="0.1">
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-success" id="save-button">Kaydet</button>
                </div>
            </div>
        </div>
    </div>


    <div class="modal fade" id="mdlKoordinatAra" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Koordinata Git</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" style="font-size: 12px;" aria-label="Close"></button>
                </div>
