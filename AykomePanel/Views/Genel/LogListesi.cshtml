@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Genel/Kullanıcı Logları";
}
@section Styles {
    <style>
        .chckLst {
            background-color: #00987933;
            padding: 5px;
            border-radius: 8px;
            height: 110px;
            overflow: auto;
        }
    </style>
}
<div class="cerceve">
    <h1 class="baslik1">Kullanıcı Logları</h1>
    <div class="tblsearch">
        <div>
            <div class="row">
                <div class="col-4">
                    <label>Kullanıcı</label>
                    <select id="slcKullanici" class="form-select form-select-sm inputIslem" data-tip="select" data-ref="#btnVeriAra">
                        <option value="-1">Seç</option>
                    </select>
                </div>
                <div class="col-4">
                    <label> Başlangıç Tarihi</label>
                    <input id="txtBasBasTar" type="date" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
                </div>
                <div class="col-4">
                    <label>Bitiş Tarihi</label>
                    <input id="txtBasBitTar" type="date" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
                </div>
            </div>
            <div class="row">
                <div class="col-4">
                    <label>Methot</label>
                    <select id="slcMethot" class="form-select form-select-sm inputIslem" data-tip="select" data-ref="#btnVeriAra">
                        <option value="-1">Seç</option>
                        <option value="GET">Get</option>
                        <option value="POST">Post</option>
                    </select>
                </div>

                <div class="col-4">
                    <label>Path</label>
                    <input id="txtPath" type="text" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
                </div>
                <div class="col-4">
                    <label>Query String</label>
                    <input id="txtQueryString" type="text" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
                </div>
                <div class="col-4">
                    <label>Request Body</label>
                    <input id="txtRequestBody" type="text" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
                </div>
                <div class="col-4">
                    <label>İp Addresi</label>
                    <input id="txtIpAddress" type="text" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
                </div>
            </div>
        </div>
        <div class="mt-3 d-flex justify-content-between">
            <div><button type="button" class="btnFiltreClear btn btn-secondary btn-sm "><i class="bx bx-square"></i>Temizle</button></div>
            <div class="d-flex gap-1">
                <button id="btnVeriAra" type="button" class="btnSearch btn btn-warning btn-sm"><i class="bx bx-search"></i><span>Ara</span></button>
            </div>

        </div>
    </div>
    <table class="fixtbl mt-3" cellpadding="0" cellspacing="0" border="0">
        <thead class="tblhead">
            <tr>
                <th>ID</th>
                <th>Method</th>
                <th>Tarih</th>
                <th>İp Adresi</th>
                <th>Kullanıcı</th>
                <th>Path</th>
                <th>QueryString</th>
                <th>RequestBody</th>
            </tr>
        </thead>
    </table>

    <div class="position-relative">
        <div class="overflow-auto tblbotsty">
            <table class="table fixtbl">
                <tbody id="tblData">
                </tbody>
            </table>
        </div>
        <div class="tblload" hidden="hidden">
            <i class="bx bx-search bx-tada fs-4"></i>Yükleniyor...
        </div>
    </div>
    <div class="d-flex justify-content-between align-items-center mt-2">
        <div class="fs-9">
            <span>Toplam Kayıt</span>
            <span id="lblgosterim" class="ms-1 me-1 text-secondary"></span>
            <span id="lbltoplamkayit"></span>
        </div>
        <div>
            <button type="button" class="btn btn-warning btn-sm btnDatOnc"><< Bir Önceki Sayfa</button>
            <button type="button" class="btn btn-warning btn-sm btnDatSon">Bir Sonraki Sayfa>> </button>
        </div>
    </div>
    @section Scripts {
        <script src="~/js/_genel/loglars.js"></script>
    }

