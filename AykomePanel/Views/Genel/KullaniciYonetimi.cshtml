@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Kullanici Yönetimi";
}
@section Styles {
    @*  <link href="~/css/leaflet.css" rel="stylesheet" /> *@
    <style>
        .hesap-logo {
            width: 150px;
            height: 150px;
            text-align: center;
            position: relative;
            background-color: #efefef;
        }

            .hesap-logo img {
            }

        .imgdfv {
            display: inline-block;
            background-color: #efefef6b;
            position: relative;
            margin: 3px;
            border-radius: 7px;
        }

            .imgdfv .imgresw {
                width: 150px;
                height: 150px;
                object-fit: contain;
            }

            .imgdfv a {
                position: absolute;
                bottom: 0;
                left: 50%;
                background-color: #fff;
                padding: 0 3px;
                cursor: pointer;
            }

        .arnk {
            width: 10px;
            height: 10px;
            display: inline-block;
            margin-right: 5px;
        }

        .alttbl {
            background-color: #ffc1072b;
            margin-bottom: 0;
        }

            .alttbl td {
                font-size: .7rem !important;
            }


        .abirimSec {
            text-decoration: none;
            font-size: .8rem;
            width: 90px;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .imgPhoto {
            width: 40px;
        }
    </style>
}
<div class="cerceve">
    <h1 class="baslik1">Kullanici Yönetimi</h1>
    <div class="text-end">
        <button type="button" class="btn btn-outline-info btn-sm opnModal" id="btnMdlWfs" data-ref="#mdlVeri" data-temizle="false"><i class="bx bx-map-pin"></i> Yeni Kullanıcı Ekle</button>
        @* <button type="button" class="btn btn-outline-danger btn-sm opnModal" id="btnMdlWms" data-ref="#mdlVeri2" data-temizle="false"><i class="bx bx-map-alt"></i> WMS Katman Ekle</button> *@
        @*         <button type="button" class="btn btn-outline-success btn-sm opnModal" id="btnMdlDB" data-ref="#mdlVeri3" data-temizle="false"><i class='bx bx-data'></i> DB Katman Ekle</button> *@
    </div>

    <table class="fixtbl mt-3" cellpadding="0" cellspacing="0" border="0">
        <thead class="tblhead">
            <tr>
                <th class="wdt-kucuk">Resim</th>
                <th class="wdt-kucuk">ID</th>
                <th>Kurum</th>
                <th>Birim</th>
                <th>Ad Soyad</th>
                <th>Kullanıcı Adı</th>
                <th>Çep Tlf. No</th>
                <th>Aktif</th>
                <th class="wdt-kucuk"></th>
            </tr>
        </thead>
    </table>

    <div class="position-relative">
        <div class="overflow-auto tblbotsty">
            <table class="table fixtbl">
                <tbody id="tblData">
                </tbody>
            </table>
        </div>
        <div class="tblload" hidden="hidden">
            <i class="bx bx-search bx-tada fs-4"></i>Yükleniyor...
        </div>
    </div>

    <div class="modal" id="mdlVeri" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Kullanıcı Yönetimi</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-2">
                        <div class="col-6">
                            <div class="row">
                                <div class="col-6">
                                    <div class="lblDiv">
                                        <div class="lbll">Kurum</div>
                                    </div>
                                    <div class="ltxt">
                                        <select class="form-select" id="slcKurum" data-validate-hint="Zorunlu Alan!" data-validate-func="selectbox">
                                            <option value="">Seç</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="lblDiv">
                                        <div class="lbll">Birim</div>
                                    </div>
                                    <div class="ltxt">
                                        <select class="form-select" id="slcBirim" data-validate-hint="Zorunlu Alan!" data-validate-func="selectbox">
                                            <option value="-1">Seç</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="col-6">
                                    <div class="lblDiv">
                                        <div class="lbll">Adı Soyadı</div>
                                    </div>
                                    <div class="ltxt">
                                        <input type="text" class="form-control form-control-sm" id="txtAdiSoyadi" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="lblDiv">
                                        <div class="lbll">Kullanıcı Adı</div>
                                    </div>
                                    <div class="ltxt">
                                        <input type="text" class="form-control form-control-sm" id="txtKullaniciAdi" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                                    </div>
                                </div>
                                <div class="col-6 mt-1 d-flex align-items-center">
                                    <label class="ltxt">
                                        Aktif <input type="checkbox" id="txtAktiflik" checked="checked" />
                                    </label>
                                </div>
                                <div class="col-6">
                                    <div class="lblDiv">
                                        <div class="lbll">Şifre</div>
                                    </div>
                                    <div class="ltxt">
                                        <input type="text" class="form-control form-control-sm" id="txtKullaniciSifre" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="lblDiv">
                                        <div class="lbll">Gsm NO</div>
                                    </div>
                                    <div class="ltxt">
                                        <input type="text" class="form-control form-control-sm" id="txtgsmno" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="hesap-logo">
                            </div>
                            <div class="mt-3">
                                <input class="form-control form-control-sm" id="filMusteriFotograf" type="file" accept=".png, .jpg, .jpeg">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnKaydet" class="btn btn-success btn-sm">
                        <i class='bx bx-check'></i>
                        <span>Kaydet</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal" id="mdlSil" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Kullanıcı Silmek</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    <button type="button" class="btn btn-full"><i class="ph ph-frame-corners"></i></button>
                </div>
                <div class="modal-body">
                    <p>Bu Kayıt Tamamen Silinsin mi?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnSil" class="btn btn-success btn-sm">
                        <i class='bx bx-check'></i>
                        <span>Sil</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/_genel/kullanici_yonetimi.js"></script>
}

