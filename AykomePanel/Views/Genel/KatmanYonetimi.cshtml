                            </div>
                        </div>

                        <div class="col mt-2">
                            <div class="lblDiv">
                                <div class="lbll">User Name</div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class="form-control form-control-sm" value="" id="txtUserName2" />
