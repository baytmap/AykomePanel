@{
    ViewData["Title"] = "Katman Yönetimi";
}
@section Styles {
    @*  <link href="~/css/leaflet.css" rel="stylesheet" /> *@
    <style>
        .arnk {
            width: 10px;
            height: 10px;
            display: inline-block;
            margin-right: 5px;
        }

        .alttbl {
            background-color: #ffc1072b;
            margin-bottom: 0;
        }

            .alttbl td {
                font-size: .7rem !important;
            }

        #map {
            width: 100%;
            height: 550px;
        }

        .abirimSec {
            text-decoration: none;
            font-size: .8rem;
            width: 90px;
            overflow: hidden;
            text-overflow: ellipsis;
        }
    </style>
}
<div class="cerceve">
    <h1 class="baslik1">Katman Yönetimi</h1>
    <div class="text-end">
        <button type="button" class="btn btn-outline-info btn-sm opnModal" id="btnMdlWfs" data-ref="#mdlVeri" data-temizle="false"><i class="bx bx-map-pin"></i> WFS Katman Ekle</button>
        @* <button type="button" class="btn btn-outline-danger btn-sm opnModal" id="btnMdlWms" data-ref="#mdlVeri2" data-temizle="false"><i class="bx bx-map-alt"></i> WMS Katman Ekle</button> *@
        @*         <button type="button" class="btn btn-outline-success btn-sm opnModal" id="btnMdlDB" data-ref="#mdlVeri3" data-temizle="false"><i class='bx bx-data'></i> DB Katman Ekle</button> *@
