                        <span>Kaydet</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal" id="mdlBirim" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Kurum/Birim</h5>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col">
                            <select class="form-select" id="slcKurum">
                                <option value="">Seç</option>
                            </select>
                        </div>
                        <div class="col">
                            <select class="form-select" id="slcBirim">
                                <option value="">Seç</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">

                    <button type="button" id="btnKurBirIpt" class="btn btn-danger btn-sm">
                        <i class='bx bx-check'></i>
                        <span>İptal</span>
                    </button>

                    <button type="button" id="btnKurBir" disabled="disabled" class="btn btn-success btn-sm">
                        <i class='bx bx-check'></i>
                        <span>Kaydet</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal" id="mdlSil" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Kullanıcı Silmek</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
