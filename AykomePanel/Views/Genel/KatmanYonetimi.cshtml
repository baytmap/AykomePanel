                </div>
                <div class="modal-footer">
                    <button type="button" id="btnSil" class="btn btn-success btn-sm">
                        <i class='bx bx-check'></i>
                        <span>Sil</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div id="custom-menu" style="display:none;">
        <button onclick="alert('Tıklama 1')">Tıklama 1</button>
        <button onclick="alert('Tıklama 2')">Tıklama 2</button>
    </div>


</div>
