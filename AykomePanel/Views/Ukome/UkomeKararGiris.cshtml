@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Ukome/Ukome Kararları Girişi";
}
@section Styles {
    <link href="~/css/leaflet.css" rel="stylesheet" />
    <style>
        #map {
            width: 100%;
            height: 550px;
        }
    </style>
}
<div class="cerceve">
    <h1 class="baslik1">Ukome Kararları Girişi</h1>
    <div class="tblsearch">
        <div class="row row-cols-4">
            <div class="col">
                <label>Karar Tarihi Başlangıç</label>
                <input id="txtFilKararTar1" type="date" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
            <div class="col">
                <label>Karar Tarihi Bitiş</label>
                <input id="txtFilKararTar2" type="date" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
            <div class="col">
                <label>Karar No</label>
                <input id="txtFiKararNo" type="text" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
            <div class="col">
                <label>Konusu</label>
                <input id="txtFiKonusu" type="text" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
        </div>

        <div class="mt-3 d-flex justify-content-between">
            <div><button type="button" class="btnFiltreClear btn btn-secondary btn-sm "><i class="bx bx-square"></i>Temizle</button></div>
            <div class="d-flex gap-1">
                <button id="btnExcel" disabled="disabled" type="button" class="btn btn-success btn-sm" title="Excel"><i class='bx bxs-file-export'></i>Excel</button>
                <button id="btnVeriAra" type="button" class="btnSearch btn btn-warning btn-sm"><i class="bx bx-search"></i><span>Ara</span></button>
            </div>

        </div>
    </div>

    <table class="fixtbl mt-3" cellpadding="0" cellspacing="0" border="0">
        <thead class="tblhead">
            <tr>
                <th>Ukome Karar No</th>
                <th>Karar Tarihi</th>
                <th>Konusu</th>
            </tr>
        </thead>
    </table>

    <div class="position-relative">
        <div class="overflow-auto tblbotsty">
            <table class="table fixtbl">
                <tbody id="tblData">
                </tbody>
            </table>
        </div>
        <div class="tblload" hidden="hidden">
            <i class="bx bx-search bx-tada fs-4"></i>Yükleniyor...
        </div>
    </div>

    @section Scripts {
        <script src="~/js/LeafletJS/leaflet-src.js"></script>
        <script type="text/javascript">

            var excData = [];

            zxc.baslarken(function () {
                fncIlkAcilis(true);

                zxc("#btnVeriAra").click(function () {
                    fncIlkAcilis();
                });

                zxc('#btnExcel').click(() => {
                    if (excData.length > 0)
                        fncExcel1("Ukome Kararları Girişi", excData);
                });
                fncTblHeight();
            })

            const fncTblHeight = () => {
                var q = document.body.clientHeight,
                    w = document.querySelector('.home-content').offsetHeight,
                    e = document.querySelector('.tblsearch').offsetHeight,
                    r = document.querySelector('.fixtbl').offsetHeight;

                var we = (q - (w + e + r + 175));
                if (we < 200)
                    we = 250;
                document.querySelector('.overflow-auto.tblbotsty').style.height = we + "px";
            }

            function fncIlkAcilis(Tanim = false) {
                var btnSarch = zxc("#btnVeriAra").dom;
                PostJson('/api/Api_Ukome/GetKararlarGirisLst', {
                    Param1: zxc('#txtFilKararTar1').value(),
                    Param2: zxc('#txtFilKararTar2').value(),
                    Param3: zxc('#txtFiKararNo').value(),
                    Param4: zxc('#txtFiKonusu').value()
                }, function (data) {
                    var html;
                    if (data.veri != null) {
                        html = '';
                        data.veri.forEach(q =>
                            html = html.concat(`<tr>
                                            <td>${q.KararNo}</td>
                                            <td>${zxc.tarihParse(q.Tarihi)}</td>
                                            <td>${q.Konusu}</td>
                                            </tr>`));
                        zxc('#tblData').html(html);
                        zxc('#btnExcel').attrSil('disabled');

                        var ar2 = ["Ukome Karar No", "Karar arihi", "Konusu"];
                        excData.push(ar2);
                        data.veri.forEach(function (q) {
                            var ar = [q.KararNo, zxc.tarihParse(q.Tarihi), q.Konusu];
                            excData.push(ar)
                        });
                    }
                }, function () {
                    zxc("#btnVeriAra,#btnExcel").attr('disabled', 'disabled');
                    zxc('.tblload:0').attrSil('hidden');
                    zxc('#tblData').html(" ");
                    excData = [];
                }, function () {
                    zxc("#btnVeriAra").attrSil('disabled');
                    zxc('.tblload:0').attr('hidden', 'hidden');
                })
            }



        </script>
    }
</div>