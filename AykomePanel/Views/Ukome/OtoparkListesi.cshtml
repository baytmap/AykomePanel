@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Ukome/Otopark Listesi";
}
@section Styles {
    <link href="~/css/leaflet.css" rel="stylesheet" />
    <style>
        #map {
            width: 100%;
            height: 550px;
        }
    </style>
}
<div class="cerceve">
    <h1 class="baslik1">Otopark Listesi</h1>
    <div class="tblsearch">
        <div class="row row-cols-5">
            <div class="col">
                <label>Otopark İsmi</label>
                <input id="txtFilOtoparkIsmi" type="text" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
            <div class="col">
                <label>Otopark Tipi</label>
                <select id="txtFilOtoparkTipi" class="form-select form-select-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra">
                    <option></option>
                </select>
            </div>
            <div class="col">
                <label>Araç Kapasitesi</label>
                <input id="txtFiAracKapas" type="text" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
            <div class="col">
                <label>Ukome Karar Tarihi</label>
                <input id="txtFiUkomKakTar" type="text" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
            <div class="col">
                <label>Ukome Karar No</label>
                <input id="txtFiUkomKakNo" type="text" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
        </div>

        <div class="mt-3 d-flex justify-content-between">
            <div><button type="button" class="btnFiltreClear btn btn-secondary btn-sm "><i class="bx bx-square"></i>Temizle</button></div>
            <div class="d-flex gap-1">
                <button id="btnExcel" disabled="disabled" type="button" class="btn btn-success btn-sm" title="Excel"><i class='bx bxs-file-export'></i>Excel</button>
                <button id="btnVeriAra" type="button" class="btnSearch btn btn-warning btn-sm"><i class="bx bx-search"></i><span>Ara</span></button>
            </div>

        </div>
    </div>

    <table class="fixtbl mt-3" cellpadding="0" cellspacing="0" border="0">
        <thead class="tblhead">
            <tr>
                <th>Otopark İsmi</th>
                <th>Araç Kapasitesi</th>
                <th>Otopark Tipi</th>
                <th>Ukome Karar Tarihi</th>
                <th>Ukome Karar No</th>
            </tr>
        </thead>
    </table>

    <div class="position-relative">
        <div class="overflow-auto tblbotsty">
            <table class="table fixtbl">
                <tbody id="tblData">
                </tbody>
            </table>
        </div>
        <div class="tblload" hidden="hidden">
            <i class="bx bx-search bx-tada fs-4"></i>Yükleniyor...
        </div>
    </div>

    @section Scripts {
        <script src="~/js/LeafletJS/leaflet-src.js"></script>
        <script type="text/javascript">

            var excData = [];

            zxc.baslarken(function () {
                fncIlkAcilis(true);

                zxc("#btnVeriAra").click(function () {
                    fncIlkAcilis();
                });

                zxc('#btnExcel').click(() => {
                    if (excData.length > 0)
                        fncExcel1("Otopark Listesi", excData);
                });
                fncTblHeight();
            })

            const fncTblHeight = () => {
                var q = document.body.clientHeight,
                    w = document.querySelector('.home-content').offsetHeight,
                    e = document.querySelector('.tblsearch').offsetHeight,
                    r = document.querySelector('.fixtbl').offsetHeight;

                var we = (q - (w + e + r + 175));
                if (we < 200)
                    we = 250;
                document.querySelector('.overflow-auto.tblbotsty').style.height = we + "px";
            }

            function fncIlkAcilis(Tanim = false) {
                var btnSarch = zxc("#btnVeriAra").dom;
                PostJson('/api/Api_Ukome/GetOtoParkLst', {
                    Param1: zxc('#txtFilOtoparkIsmi').value(),
                    Param2: zxc('#txtFilOtoparkTipi').value(),
                    Param3: zxc('#txtFiAracKapas').value(),
                    Param4: zxc('#txtFiUkomKakTar').value(),
                    Param5: zxc('#txtFiUkomKakNo').value()
                }, function (data) {
                    var html;
                    if (Tanim) {
                        if (data.veri2 != null) {
                            html = '<option value="">Seç</option>';
                            data.veri2.forEach(q =>
                                html = html.concat(`<option value="${q.Key}">${q.Val}</option>`));
                            document.getElementById('txtFilOtoparkTipi').innerHTML = html;
                        }
                    }
                    if (data.veri != null) {
                        html = '';
                        data.veri.forEach(q =>
                            html = html.concat(`<tr>
                                                                                            <td>${q.OtoparkIsmi}</td>
                                                                                            <td>${q.ArasKapasitesi}</td>
                                                                                            <td>${q.OtoparkTipi}</td>
                                                                                            <td>${zxc.tarihParse(q.UkomeKararTarihi)}</td>
                                                                                            <td>${q.UkomeKararNo}</td>
                                                                    </tr>`));
                        zxc('#tblData').html(html);
                        zxc('#btnExcel').attrSil('disabled');

                        var ar2 = ["Otopark İsmi", "Araç Kapasitesi", "Otopark Tipi", "Ukome Karar Tarihi", "Ukome Karar No"];
                        excData.push(ar2);
                        data.veri.forEach(function (q) {
                            var ar = [q.OtoparkIsmi, q.ArasKapasites, q.OtoparkTip, zxc.tarihParse(q.UkomeKararTarihi), q.UkomeKararNo];
                            excData.push(ar)
                        });
                    }
                }, function () {
                    zxc("#btnVeriAra,#btnExcel").attr('disabled', 'disabled');
                    zxc('.tblload:0').attrSil('hidden');
                    zxc('#tblData').html(" ");
                    excData = [];
                }, function () {
                    zxc("#btnVeriAra").attrSil('disabled');
                    zxc('.tblload:0').attr('hidden', 'hidden');
                })
            }
        </script>
    }
</div>