        function fncHaritaDbKAydet() {
            var q = document.querySelector('#txtkordlst').children,
                w = [];

            for (var i = 0; i < q.length; i++)
                w.push({ lat: q[i].getAttribute('data-lat'), lng: q[i].getAttribute('data-lng') });
            console.log(w);
        }

