    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title ps-3 pe-3">Bu Açılan Modal'da İlgili Veri Yönetilecek</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                <button type="button" class="btn btn-full"><i class="ph ph-frame-corners"></i></button>
            </div>
            <div class="modal-body">
                <div class="row row-cols-2 pe-3 ps-3">
                    <div class="col">
                        <div class="lblDiv">
                            <div class="lbll">Kaplama Cinsi<span class="szr">*</span></div>
                        </div>
                        <div class="ltxt">
                            <input type="text" class='form-control ' value="" id="txtAdiSoyadi" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
