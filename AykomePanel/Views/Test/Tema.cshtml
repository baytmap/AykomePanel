@{
    ViewData["Title"] = "Privacy Policy";
}
@section Styles {
    <link href="~/css/leaflet.css" rel="stylesheet" />
    <link href="~/css/leaflet.draw.css" rel="stylesheet" />
    <style>
        #map {
            width: 100%;
            height: 550px;
        }

        .spnkord {
            font-size: .7rem;
            display: block;
        }
    </style>
}
<fieldset>
    <div class="form-group">
        Dosya
        <div class="custom-file custom-group">
            <input id="Dosya" name="Dosya" type="file" class="custom-file-input">
            <label for="Dosya" class="custom-file-label eypDisiLabel">Belge Ekle...</label>
        </div>
    </div>
    <div class="row">


        <div class="col-sm-12 col-md-12 col-lg-12">
            <div class="form-group">
                <div class="custom-group">
                    @Html.Label("Cihaz")
                    @Html.DropDownList("Cihaz_Id", new List<SelectListItem> { new SelectListItem { Text = "Seçiniz", Value = "0", Selected = true } }, new { @class = "form-control select2_demo_1" })
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-sm-12 col-md-12 col-lg-12">
            <div class="form-group">
                <div class="custom-group">
                    @Html.Label("Sertifika")
                    @Html.DropDownList("Sertifika_Id", new List<SelectListItem> { new SelectListItem { Text = "Seçiniz", Value = "0", Selected = true } }, new { @class = "form-control select2_demo_1" })
                </div>
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-sm-12 col-md-12 col-lg-12">
            <div class="form-group">
                @Html.Label("Şifre")
                @Html.Password("Sifre", "123456", new { @class = "form-control", placeholder = "Şifrenizi Giriniz", required = "required" })
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-sm-12 col-md-12 col-lg-12">
            <div class="form-group">
                <button type="button" class="btn btn-primary" id="imzaBilgisiModalImzala">İmzala</button>
            </div>
        </div>
    </div>

</fieldset>

<button onclick="createPDF()" type="button">PDF Oluştur</button>
<button onclick="uploadPDF()" type="button">PDF Oluştur ve Sunucuya Gönder</button>

<button type="button" class="btn btn-primary" onclick="fncModalAc('#ruhsatOnayModal')" data-toggle="modal" data-target="#ruhsatOnayModal">
    Ruhsat Onay Formu
</button>

<div class="modal fade" id="ruhsatOnayModal" tabindex="-1" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="ruhsatOnayModalLabel">Ruhsat Onay Formu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col">
                        <div class="altbaslik">Konya Büyükşehir Belediyesi</div>

                        <div class="form-group">
                            <label for="girisTarihi">Giriş Tarihi</label>
                            <input type="date" class="form-control" id="girisTarihi" value="2023-12-21">
                        </div>

                        <div class="form-group mt-1">
                            <label for="girisNumarasi">Giriş Numarası</label>
                            <input type="text" class="form-control" id="girisNumarasi" value="175431">
                        </div>

                        <div class="altbaslik mt-2">UKOME</div>

                        <div class="form-group mt-1">
                            <label for="ustBirim1">UKOME Açıklama</label>
                            <textarea class="form-control" id="ustBirim1" rows="3">USTBIRIMCODE = 2 AND AYK_OLUR.MESAJ</textarea>
                        </div>

                        <div class="altbaslik mt-2">Yol Yapım Bakım Şube Müdürlüğü </div>
                        <div class="form-group">
                            <label for="ustBirim2">Açıklama</label>
                            <textarea class="form-control" id="ustBirim2" rows="3">USTBIRIMCODE = 5 AND AYK_OLUR.MESAJ</textarea>
                        </div>

                    </div>
                    <div class="col">
                        <div class="form-group">
                            <label for="durum">Durum</label>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="yolYipranma">
                                <label class="form-check-label" for="yolYipranma">Yol Yıpranma</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="ruhsatBedeli">
                                <label class="form-check-label" for="ruhsatBedeli">Ruhsat Bedeli</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="teminatBedeli">
                                <label class="form-check-label" for="teminatBedeli">Teminat Bedeli</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="kaziDolguBedeli">
                                <label class="form-check-label" for="kaziDolguBedeli">Kazı Dolgu Bedeli</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="kaplamaBedeli">
                                <label class="form-check-label" for="kaplamaBedeli">Kaplama Bedeli</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="altyapiKaziIzinHarci">
                                <label class="form-check-label" for="altyapiKaziIzinHarci">Altyapı Kazı İzin Harcı</label>
                            </div>
                        </div>
                        <div class="form-group mt-1">
                            <label for="fiyatYili">Fiyat Yılı</label>
                            <select class="form-control" id="txtfiyatYili">
                                <option>2024</option>
                                <option>2023</option>
                                <option>2022</option>
                            </select>
                        </div>
                        <div class="form-group mt-2">
                            <label for="aciklama">Açıklama</label>
                            <textarea class="form-control" id="aciklama" rows="3">Yukarıda boyu ve yeri belirlenmiş olan tranşe cümlesinin devamına tarihlerden sonra “kurum adı combo box + tarafından” kelimesi eklenerek seçildiğinde bu şekilde ruhsata eklenecektir.</textarea>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-primary">Tamam</button>
            </div>
        </div>
    </div>
</div>

