                                <tr data-lat="34.52466147177175" data-lng="-46.09863281250001"><td>3</td><td>34.52466147177175</td><td>-46.09863281250001</td></tr>
                                <tr data-lat="34.52466147177175" data-lng="-46.09863281250001"><td>4</td><td>34.52466147177175</td><td>-46.09863281250001</td></tr>
                                <tr data-lat="39.977120098439634" data-lng="-34.67285156250001"><td>5</td><td>39.977120098439634</td><td>-34.67285156250001</td></tr>
                                <tr data-lat="42.032974332441405" data-lng="-51.28417968750001"><td>6</td><td>42.032974332441405</td><td>-51.28417968750001</td></tr>
                                <tr data-lat="42.032974332441405" data-lng="-51.28417968750001"><td>7</td><td>42.032974332441405</td><td>-51.28417968750001</td></tr>
                                <tr data-lat="42.48830197960227" data-lng="-55.76660156250001"><td>8</td><td>42.48830197960227</td><td>-55.76660156250001</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">

                    <button type="button" class="btn btn-danger " data-bs-dismiss="modal">
                        <span class="ph ph-plus  me-1"></span>
                        İptal
                    </button>
                    <button type="button" id="btnInsert" class="btn btn-primary">
                        <span class="ph ph-checks me-1"></span>
                        Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="toast-container position-fixed p-3 start-50 translate-middle-x" style="top: 25px;">
        <div id="liveToast" class="toast align-items-center" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex  align-items-center ps-2">
                <i class="bi bi-search"></i>
                <div class="toast-body" id="toastmes">
                </div>
                <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>
