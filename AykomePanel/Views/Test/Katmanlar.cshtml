@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AykomePanel</title>
    <link href='https://unpkg.com/boxicons@2.0.7/css/boxicons.min.css' rel='stylesheet'>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/leaflet.css" />
    <link rel="stylesheet" href="~/css/leafletdraw.css" />
    <style>
        .logo-details {
            width: 100%;
            display: flex;
            padding-top: 20px;
            justify-content: center;
        }

            .logo-details img {
                min-width: 60px;
                max-width: 74%;
            }

        .home-content {
            height: 60px;
            display: flex;
            align-items: center;
            background-color: #fff;
        }

            .home-content .bx-menu,
            .home-content .text {
                color: #11101d;
                font-size: 35px;
            }

            .home-content .bx-menu {
                margin: 0 15px;
                cursor: pointer;
            }

            .home-content .text {
                font-size: 26px;
                font-weight: 600;
            }

      
        .toast-container {
            z-index: 1550;
        }

        .spnkord {
            font-size: .7rem;
            display: block;
        }

        .katmLan {
            display: flex;
        }

            .katmLan .katmanPnl {
                width: 230px;
                background-color: #fff;
            }

                .katmLan .katmanPnl h1 {
                    font-size: 1rem;
                    color: #0a9b7e;
                    line-height: 31px;
                    background-color: #cce0e0;
                    margin-top: 10px;
                    margin-bottom: 0;
                    text-align: center;
                }

                .katmLan .katmanPnl ul {
                    list-style: none;
                    padding: 0;
                }

                    .katmLan .katmanPnl ul li:nth-child(2n+1) {
                        background-color: #d7e6dd5e;
                    }

            .katmLan .map {
                width: calc(100% - 230px);
            }

                .katmLan .map #map {
                    height: calc(100vh - 60px);
                }


        .fobvre {
            display: flex;
            align-items: center;
            gap: 5px;
            padding: 3px 7px;
            margin-bottom: 1px;
            cursor: pointer;
            justify-content: space-between;
        }

            .fobvre .bbhd1 {
                overflow: hidden;
            }

                .fobvre .bbhd1 .ktmLbl {
                    font-size: .8rem;
                }

                    .fobvre .bbhd1 .ktmLbl:hover {
                        color: #ff2c2c;
                    }

            .fobvre .bbhd2 a, .btnKtmnShow {
                background-color: #6da4aa46;
                color: #009879;
                width: 25px;
                display: inline-block;
                text-align: center;
            }

                .fobvre .bbhd2 a, .btnKtmnShow.aktiv {
                    background-color: #309136;
                    color: #fff;
                }

                    .fobvre .bbhd2 a i {
                        position: relative;
                        top: 2px;
                    }

        .bbhd2 a:hover, .bbhd2 a.active {
            background-color: #dc3545a1;
            color: #751821a1;
        }

        .leaflet-touch .leaflet-bar a {
            background-color: #23d9b4;
            color: #647d78;
        }

        .widt100 {
            width: 100px;
        }

        .renk1 {
            background-color: #FED976;
        }

        .renk2 {
            background-color: #7AE2E9;
        }

        .renk3 {
            background-color: #F7A278;
        }

        .renk4 {
            background-color: #9BE37A;
        }

        .renk5 {
            background-color: #D18CF2;
        }

        .renk6 {
            background-color: #6ED5A1;
        }

        .renk7 {
            background-color: #F392E3;
        }

        .renk8 {
            background-color: #8BE0B6;
        }

        .renk9 {
            background-color: #E8A88F;
        }

        .renk10 {
            background-color: #A2E4C7;
        }

        .renk11 {
            background-color: #F3C98A;
        }

        .renk12 {
            background-color: #78E5D2;
        }

        .renk13 {
            background-color: #E694B2;
        }

        .renk14 {
            background-color: #B5E995;
        }

        .renk15 {
            background-color: #E38AC7;
        }

        .renk16 {
            background-color: #96E3B7;
        }

        .renk17 {
            background-color: #F0A9D4;
        }

        .renk18 {
            background-color: #7DE4A9;
        }

        .renk19 {
            background-color: #D9A6F2;
        }

        .renk20 {
            background-color: #A7E7BC;
        }
    </style>
</head>
