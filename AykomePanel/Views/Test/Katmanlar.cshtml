    <div class="modal" id="mdlVeri" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="mdlBaslik">Modal Başlık</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    <button type="button" class="btn btn-full"><i class="ph ph-frame-corners"></i></button>
                </div>
                <div class="modal-body">
                    <div class="row row-cols-2" id="mdlKatBad">
                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Kaplama Cinsi<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class='form-control ' value="" id="txtAdiSoyadi" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Birimi<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <select id="slcvalue1" class="form-select" data-validate-hint="Zorunlu Alan!" data-validate-func="selectbox">
                                    <option value="-1">Seç</option>
                                    <option value="1">m2</option>
                                    <option value="2">mt</option>
                                </select>
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Standart Hesap<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class='form-control ' value="" id="txtMinLength"
                                       data-validate-hint="En az 3 Karakterden oluşmalıdır !"
                                       data-validate-func="minlength" data-validate-arg="3" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Tredaş vb. Uygulanan Hesap<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class='form-control ' value="" id="txtMaxLength" data-validate-hint="En fazla 6 karakterden oluşmalıdır !" data-validate-func="maxlength" data-validate-arg="6" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">KOSKI Uygulanan Hesap<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class='form-control ' value="" id="txtMinTipi"
                                       data-validate-hint="20 den büyük bir değer olmalıdır !"
                                       data-validate-func="min" data-validate-arg="20" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Hesap Yılı<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class='form-control ' value="" id="txtMaxTipi"
                                       data-validate-hint="50'den küçük bir değer olmalıdır !" data-validate-func="max" data-validate-arg="50" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Kaplama Kodu<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class='form-control ' id="txtEposta"
                                       data-validate-hint="<%= Resources.dil.eposta%> <%= Resources.dil.hatali %>"
                                       data-validate-func="email" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Web Adresi<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class='form-control ' value="" id="txtWebAdresi"
                                       data-validate-hint="Zorunlu Alan!"
                                       data-validate-func="url" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Tarih<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="date" class='form-control ' value="" id="txtTarih"
                                       data-validate-hint="Zorunlu Alan!"
                                       data-validate-func="date" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Saat<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="time" class='form-control ' value="" id="txtSaat"
                                       data-validate-hint="Zorunlu Alan!"
                                       data-validate-func="time" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Tarih ve Saat<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="datetime-local" class='form-control ' value="" id="txtTarihVeSaat" data-validate-hint="Zorunlu Alan!" data-validate-func="datetime" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Yüzde<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class='form-control ' value="" id="txtYuzdesi" data-validate-hint="<%= Resources.dil.yuzdesi%> , <%= Resources.dil.icinbelirlenendegergecersiz %>"
                                       data-validate-func="number" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Yaş<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class='form-control ' value="" id="txtYas"
                                       data-validate-hint="<%= Resources.dil.yas%> ,<%= Resources.dil.icinbelirlenendegergecersiz %>"
                                       data-validate-func="digits" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Renk<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="color" class='form-control ' value="" id="txtColor"
                                       data-validate-hint="<%= Resources.dil.yas%> ,<%= Resources.dil.icinbelirlenendegergecersiz %>"
                                       data-validate-func="hexcolor" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">TC. Numarası<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class='form-control ' value="" id="txtTcNo" data-validate-hint="<%= Resources.dil.tcno%> ,<%= Resources.dil.icinbelirlenendegergecersiz %>"
                                       data-validate-arg="^[1-9]{1}[0-9]{9}[02468]{1}$"
                                       data-validate-func="pattern" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Ek Dosya<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="file" class="form-control  fileUpload" data-validate-hint="<%= Resources.dil.dosya%>, <%= Resources.dil.icinbelirlenendegergecersiz %>" data-validate-func="filedialog" />
                            </div>
                            <div class="progressupl">
                                <div class="progressuplic"></div>
                            </div>
                            <div class="yukimsd" id="fileDosya" runat="server"></div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Fotoğraf<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="file" class="form-control  imageUpload"
                                       data-validate-hint=" <%= Resources.dil.resim%>, <%= Resources.dil.icinbelirlenendegergecersiz %>"
                                       data-validate-func="filedialog">
                            </div>
                            <div class="progressupl">
                                <div class="progressuplic"></div>
                            </div>
                            <div class="yukimsd" id="imgResim"></div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Açıklama <span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <textarea id="txtMesaj" class='form-control'
                                          data-validate-hint="Mesaj ,<%= Resources.dil.icinbelirlenendegergecersiz %>"
                                          data-validate-func="required"></textarea>
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Şifre<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="password" class='form-control ' value="" id="txtSifre"
                                       data-validate-hint="<%= Resources.dil.sifre%> ,<%= Resources.dil.icinbelirlenendegergecersiz %>"
                                       data-validate-func="required" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Durum<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <label class="switch" style="line-height: 25px;">
                                    <input checked="checked" type="checkbox" id="txtAktif" /><span class="check"></span>
                                </label>
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">SMS Dönüşü<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <input type="radio" id="txtSms" /><span class="check"></span>
                                <span class="caption"></span>
                            </div>
                        </div>
                    </div>
                    <table class="fixtbl mt-3" cellpadding="0" cellspacing="0" border="0">
                        <thead class="tblhead">
                            <tr>
                                <th class="widt100">No</th>
                                <th>Enlem</th>
                                <th>Boylam</th>
                            </tr>
                        </thead>
                    </table>
                    <div id="dvCustomers" class="overflow-auto tblbotsty" style="height:150px;">
                        <table class="table fixtbl">
                            <tbody id="txtkordlst">
                                <tr data-lat="39.707186656826565" data-lng="-60.68847656250001">
