@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Aykome/Kaçak Kazılar";
}
<div class="cerceve">
    <h1 class="baslik1">Kaçak Kazılar</h1>
    <div class="tblsearch">
        <div class="row">
            <div class="col">
                <label>Başlangıç Tarihi</label>
                <input id="txttarih1" type="date" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
            </div>

            <div class="col">
                <label>Bitiş Tarihi</label>
                <input id="txttarih2" type="date" class="form-control form-control-sm inputIslem" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
        </div>

        <div class="mt-3 d-flex justify-content-between">
            <div><button type="button" class="btnFiltreClear btn btn-secondary btn-sm "><i class="bx bx-square"></i>Temizle</button></div>
            <div class="d-flex gap-1">
                <button id="btnVeriAra" type="button" class="btnSearch btn btn-warning btn-sm"><i class="bx bx-search"></i><span>Ara</span></button>
            </div>
        </div>
    </div>

    <table class="fixtbl mt-3" cellpadding="0" cellspacing="0" border="0">
        <thead class="tblhead">
            <tr>
                <th>MiPrinx</th>
                <th>Kullanıcı</th>
                <th>MiStyle</th>
                <th>Tarih</th>
            </tr>
        </thead>
    </table>

    <div class="position-relative">
        <div class="overflow-auto tblbotsty">
            <table class="table fixtbl">
                <tbody id="tblData">
                </tbody>
            </table>
        </div>
        <div class="tblload" hidden="hidden">
            <i class="bx bx-search bx-tada fs-4"></i>Yükleniyor...
        </div>
    </div>
    @section Scripts {
        <script src="~/js/_aykome/kacakkazilar.js"></script>
    }
</div>