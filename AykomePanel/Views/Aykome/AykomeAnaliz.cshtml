@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Aykome/Raporlar/Aykome Analiz";
}
@section Styles {
    <style>
        .chckLst {
            background-color: #00987933;
            padding: 5px;
            border-radius: 8px;
            height: 110px;
            overflow: auto;
        }
    </style>
}
<div class="cerceve">
    <h1 class="baslik1">Aykome Analiz</h1>
    <div class="tblsearch">


        <div class="row">

            <div class="col-4">
                <label>İlçe</label>
                <select id="slcIlce" class="form-select form-select-sm inputIslem" data-tip="select" data-ref="#btnVeriAra">
                    <option value="-1">Seç</option>
                </select>
            </div>
            <div class="col-4">
                <label>Mahalle</label>
                <select id="slcMahalle" class="form-select form-select-sm inputIslem" data-tip="select" data-ref="#btnVeriAra">
                    <option value="-1">Seç</option>
                </select>
            </div>
            <div class="col-4">
                <label>Cadde Sokak</label>
                <select id="slcCaddeSokak" class="form-select form-select-sm inputIslem" data-tip="select" data-ref="#btnVeriAra">
                    <option value="-1">Seç</option>
                </select>
            </div>

            <div class="col-3">
                <label>Birimler</label>
                <div class="chckLst" id="lstBirimler">
                </div>
            </div>
            <div class="col-3">
                <label>Projenin Durumu</label>
                <div class="chckLst" id="lstProjeDurumu">
                </div>
            </div>
            <div class="col-3">
                <label>Proje Tipleri</label>
                <div class="chckLst" id="lstProjeTipleri">
                </div>
            </div>

            <div class="col-3">
                <label>Kaplama Cinsi</label>
                <div class="chckLst" id="lstKaplamaCinsi">
                </div>
            </div>



        </div>
        <div class="row">
            <div class="col">
                <label>Talep Tarihi Başlangıç</label>
                <input id="txtBasBasTar" type="date" class="form-control form-control-sm inputIslem" placeholder="Başvuru Tarihi Başlangıç" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
            <div class="col">
                <label>Talep Tarihi Bitiş</label>
                <input id="txtBasBitTar" type="date" class="form-control form-control-sm inputIslem" placeholder="Başvuru Tarihi Bitiş" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
            <div class="col">
                <label>Onay Tarihi Başlangıç</label>
                <input id="txtOnyBasTar" type="date" class="form-control form-control-sm inputIslem" placeholder="Onaylanan Tarih Başlangıç" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
            <div class="col">
                <label>Onay Tarihi Bitiş</label>
                <input id="txtOnyBitTar" type="date" class="form-control form-control-sm inputIslem" placeholder="Onaylanan Tarih Bitiş" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
        </div>
        <div class="mt-3 d-flex justify-content-between">
            <div><button type="button" class="btnFiltreClear btn btn-secondary btn-sm "><i class="bx bx-square"></i>Temizle</button></div>
            <div class="d-flex gap-1">
                <button id="btnExcel" type="button" class="btn btn-success btn-sm" hidden title="Excel"><i class="bx bxs-file-export"></i>Excel</button>
                <button id="btnVeriAra" type="button" class="btnSearch btn btn-warning btn-sm"><i class="bx bx-search"></i><span>Ara</span></button>
            </div>

        </div>
    </div>
    <table class="fixtbl mt-3" cellpadding="0" cellspacing="0" border="0">
        <thead class="tblhead">
            <tr>
                <th>Ilçe</th>
                <th>Kurum</th>
                <th>Birim</th>
                <th>Durum</th>
                <th>Kaplama</th>
                <th>Tanım</th>
                <th>Proje Tanım</th>
                <th>Uzunluk</th>
                <th>Ruhsat Sayısı</th>
                <th>Ruhsat Bedeli</th>
                <th>Kaplama Bedeli</th>
                <th>Yol Yıpranma Bedeli</th>
                <th>Kazı Dolgu Bedeli</th>

            </tr>
        </thead>
    </table>

    <div class="position-relative">
        <div class="overflow-auto tblbotsty">
            <table class="table fixtbl">
                <tbody id="tblData">
                </tbody>
            </table>
        </div>
        <div class="tblload" hidden="hidden">
            <i class="bx bx-search bx-tada fs-4"></i>Yükleniyor...
        </div>
    </div>
    @section Scripts {
        <script src="~/js/_aykome/aykome_analiz.js"></script>
    }

