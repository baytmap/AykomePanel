@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Abs/Ada/Parsel/Pafta";
}
@section Styles {
    <link href="~/css/leaflet.css" rel="stylesheet" />
    <style>
        #map {
            width: 100%;
            height: 550px;
        }
    </style>
}
<div class="cerceve">
    <h1 class="baslik1">Abs>Ada/Parsel/Pafta Yönetimi</h1>
    <div class="tblsearch">
        <div class="row row-cols-4">

            <div class="col">
                <label>İlçe</label>
                <select id="slcIlce" class="form-select form-select-sm inputIslem" data-tip="select" data-ref="#btnVeriAra">
                    <option value="-1">Seç</option>
                </select>
            </div>

            <div class="col">
                <label>Mahalle</label>
                <select id="slcMahalle" class="form-select form-select-sm inputIslem" data-tip="select" data-ref="#btnVeriAra">
                    <option value="-1">Seç</option>
                </select>
            </div>

            <div class="col">
                <label>Tapu Mahallesi</label>
                <select id="slcMahalleTapu" class="form-select form-select-sm inputIslem" data-tip="select" data-ref="#btnVeriAra">
                    <option value="-1">Seç</option>
                </select>
            </div>

            <div class="col">
                <label>Kakastro Mahallesi</label>
                <select id="slcKakastro" class="form-select form-select-sm inputIslem" data-tip="select" data-ref="#btnVeriAra">
                    <option value="-1">Seç</option>
                </select>
            </div>

            <div class="col">
                <label>Ada No</label>
                <input id="txtAdaNo" type="text" class="form-control form-control-sm inputIslem" placeholder="Ada No" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
            <div class="col">
                <label>Parsel No</label>
                <input id="txtParselNo" type="text" class="form-control form-control-sm inputIslem" placeholder="Parsel No" data-tip="enter" data-ref="#btnVeriAra" />
            </div>

            <div class="col">
                <label>Pafta Adı</label>
                <input id="txtPaftaAdi" type="text" class="form-control form-control-sm inputIslem" placeholder="Pafta Adı" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
        </div>

        <div class="mt-3 d-flex justify-content-between">
            <div><button type="button" class="btnFiltreClear btn btn-secondary btn-sm "><i class="bx bx-square"></i>Temizle</button></div>
            <div class="d-flex gap-1">
                <button id="btnExcel" disabled="disabled" type="button" class="btn btn-success btn-sm" title="Excel"><i class='bx bxs-file-export'></i>Excel</button>
                <button id="btnVeriAra" type="button" class="btnSearch btn btn-warning btn-sm"><i class="bx bx-search"></i><span>Ara</span></button>
            </div>

        </div>
    </div>

    <table class="fixtbl mt-3" cellpadding="0" cellspacing="0" border="0">
        <thead class="tblhead">
            <tr>
                <th class="wdt-orta">Ada No</th>
                <th class="wdt-orta">Parsel No</th>
                <th>Pafta Adı</th>
                <th>Parsel Tip</th>
                <th>Parsel Nitelik</th>
                <th>Mahalle Adı</th>
                <th>Tapu Mahalle</th>
                <th>Kadastro Mahalle</th>
                <th>Alanı</th>
                <th></th>
            </tr>
        </thead>
    </table>

    <div class="position-relative">
        <div class="overflow-auto tblbotsty">
            <table class="table fixtbl">
                <tbody id="tblData">
                </tbody>
            </table>
        </div>
        <div class="tblload" hidden="hidden">
            <i class="bx bx-search bx-tada fs-4"></i>Yükleniyor...
        </div>
    </div>

    <div class="modal" id="mdlVeri2" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title ps-3 pe-3">Mahalle Haritası</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    <button type="button" class="btn btn-full"><i class="ph ph-frame-corners"></i></button>
                </div>
                <div class="modal-body">
                    <div id="map"></div>
                </div>
            </div>
        </div>
    </div>
    @section Scripts {
        <script src="~/js/LeafletJS/leaflet-src.js"></script>
        <script src="~/js/_abs/adaparselpaftajs.js"></script>
    }
</div>