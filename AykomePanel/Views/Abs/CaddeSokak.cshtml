@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Abs/Cadde Sokak";
}
@section Styles {
    <link href="~/css/leaflet.css" rel="stylesheet" />
    <style>
        #map {
            width: 100%;
            height: 550px;
        }
    </style>
}
<div class="cerceve">
    <h1 class="baslik1">Abs>Cadde Sokak Yönetimi</h1>
    <div class="tblsearch">
        <div class="row row-cols-4">

            <div class="col">
                <label>İlçe</label>
                <select id="slcIlce" class="form-select form-select-sm inputIslem" data-tip="select" data-ref="#btnVeriAra">
                    <option value="-1">Seç</option>
                </select>
            </div>

            <div class="col">
                <label>Mahalle</label>
                <select id="slcMahalle" class="form-select form-select-sm inputIslem" data-tip="select" data-ref="#btnVeriAra">
                    <option value="-1">Seç</option>
                </select>
            </div>


            <div class="col">
                <label>Cadde/Sokak Adı</label>
                <select id="txtCaddeSokakAdi" class="form-select form-select-sm inputIslem" data-tip="select" data-ref="#btnVeriAra">
                    <option value="-1">Seç</option>
                </select>
            </div>

            <div class="col">
                <label>Cadde/Sokak Kodu</label>
                <input id="txtCaddeSokakKodu" type="text" class="form-control form-control-sm inputIslem" placeholder="Cadde/Sokak Kodu" data-tip="enter" data-ref="#btnVeriAra" />
            </div>

            <div class="col">
                <label>Tanıtım Kodu</label>
                <div class="row">
                    <div class="col pe-0"><input id="txtTanitimKodu" type="text" class="form-control form-control-sm inputIslem" placeholder="Tuik Kodu" data-tip="enter" data-ref="#btnVeriAra" /></div>
                    <div class="col-3 ps-0"><button class="btn btn-sm btn-success" type="button">CTNO</button></div>
                </div>
            </div>

            <div class="col">
                <label>Tuik Kodu</label>
                <div class="row">
                    <div class="col pe-0"><input id="txtTuikKOdu" type="text" class="form-control form-control-sm inputIslem" placeholder="Tuik Kodu" data-tip="enter" data-ref="#btnVeriAra" /></div>
                    <div class="col-3 ps-0"><button class="btn btn-sm btn-success" type="button">DİETNT</button></div>
                </div>
            </div>
        </div>

        <div class="mt-3 d-flex justify-content-between">
            <div><button type="button" class="btnFiltreClear btn btn-secondary btn-sm "><i class="bx bx-square"></i>Temizle</button></div>
            <div class="d-flex gap-1">
                <button id="btnVeriAra" type="button" class="btnSearch btn btn-warning btn-sm"><i class="bx bx-search"></i><span>Ara</span></button>
            </div>

        </div>
    </div>

    <table class="fixtbl mt-3" cellpadding="0" cellspacing="0" border="0">
        <thead class="tblhead">
            <tr>
                <th>İlçe Adı</th>
                <th>Mahalle Adı</th>
                <th>Cadde Sokak Adı</th>
                <th>Cadde Sokak Ref</th>
                <th>Cadde Sokak Kodu</th>
                <th>Cadde Sokak</th>
                <th>Tanıtım No</th>
                <th>Die Tanıtım No</th>
                <th>Meclis Karar No</th>
                <th>Meclis Karar Tarihi</th>
                <th>Valilik Karar No</th>
                <th>Valilik Karar Tarihi</th>
                <th>Veriliş Tarihi</th>
                <th>Cadde Sokak Bilgisi</th>
                <th></th>
            </tr>
        </thead>
    </table>

    <div class="position-relative">
        <div class="overflow-auto tblbotsty">
            <table class="table fixtbl">
                <tbody id="tblData">
                </tbody>
            </table>
        </div>
        <div class="tblload" hidden="hidden">
            <i class="bx bx-search bx-tada fs-4"></i>Yükleniyor...
        </div>
    </div>


    <div class="modal" id="mdlVeri" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Cadde Sokak</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    <button type="button" class="btn btn-full"><i class="ph ph-frame-corners"></i></button>
                </div>
                <div class="modal-body">
                    <div class="row row-cols-2 mb-2">
                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Cadde Sokak Kod</div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class="form-control form-control-sm" value="" id="txtCaddeSokKot" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                            </div>
                        </div>
                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Cadde Sokak Adı</div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class="form-control form-control-sm" value="" id="txtCaddeSokAd" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Cadde Sokak?</div>
                            </div>
                            <div class="ltxt">
                                <select id="slcCadFilSok" class="form-select form-select-sm" data-validate-hint="Zorunlu Alan!" data-validate-func="selectbox">
                                    <option value="-1">Seç</option>
                                </select>
                            </div>
                        </div>
                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Tanıtım No</div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class="form-control form-control-sm" value="" id="txtTanitimNo" />
                            </div>
                        </div>
                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Meclis Karar No</div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class="form-control form-control-sm" value="" id="txtFilMecKarNo" />
                            </div>
                        </div>
                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Meclis Karar Tarihi</div>
                            </div>
                            <div class="ltxt">
                                <input type="date" class="form-control form-control-sm" value="" id="txtFilMecKarTar" />
                            </div>
                        </div>

                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Valilik Karar No</div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class="form-control form-control-sm" value="" id="txtValKarNo" />
                            </div>
                        </div>
                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Valilik Karar Tarihi</div>
                            </div>
                            <div class="ltxt">
                                <input type="date" class="form-control form-control-sm" value="" id="txtValKarTar" />
                            </div>
                        </div>
                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Kaydeden</div>
                            </div>
                            <div class="ltxt">
                                <input type="text" class="form-control form-control-sm" value="" id="txtFilKayd" />
                            </div>
                        </div>
                        <div class="col">
                            <div class="lblDiv">
                                <div class="lbll">Kayıt Tarihi</div>
                            </div>
                            <div class="ltxt">
                                <input type="datetime-local" class="form-control form-control-sm" value="" id="txtFilKaydTarh" />
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="lblDiv">
                                <div class="lbll">Cadde/Sokak Bilgisi</div>
                            </div>
                            <div class="ltxt">
                                <textarea id="txtFilCadSokBil" class="form-control form-control-sm"></textarea>
                            </div>
                        </div>
                    </div>

                    <div>
                        <h2>Numarataj Bilgisi</h2>
                        <div>
                            <div class="position-relative">
                                <div class="overflow-auto tblbotsty2">
                                    <table class="table">
                                        <thead class="tblhead2">
                                            <tr>
                                                <th>İlçe Adı</th>
                                                <th>Mahalle Adı</th>
                                                <th>Die Tanıtım No</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tblDataNumarataj">
                                            <tr>
                                                <td>İlçe Adı</td>
                                                <td>Mahalle Adı</td>
                                                <td>Die Tanıtım No</td>
                                            </tr>
                                            <tr>
                                                <td>İlçe Adı</td>
                                                <td>Mahalle Adı</td>
                                                <td>Die Tanıtım No</td>
                                            </tr>
                                            <tr>
                                                <td>İlçe Adı</td>
                                                <td>Mahalle Adı</td>
                                                <td>Die Tanıtım No</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" id="btnInsert" class="btn btn-success">
                        <span class="ph ph-checks me-1"></span>
                        Evrak
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal" id="mdlVeri2" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title ps-3 pe-3">Harita</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    <button type="button" class="btn btn-full"><i class="ph ph-frame-corners"></i></button>
                </div>
                <div class="modal-body">
                    <div id="map"></div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/LeafletJS/leaflet-src.js"></script>
    <script src="~/js/_abs/caddesokak.js"></script>
}

