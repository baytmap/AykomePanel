@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Abs/Mahalle";
}
@section Styles {
    <link href="~/css/leaflet.css" rel="stylesheet" />
    <style>
        #map {
            width: 100%;
            height: 550px;
        }
    </style>
}
<div class="cerceve">
    <h1 class="baslik1">Abs>Mahalle Yönetimi</h1>
    <div class="tblsearch">
        <div class="row row-cols-4">

            <div class="col">
                <label>İlçe</label>
                <select id="slcIlce" class="form-select form-select-sm inputIslem" data-tip="select" data-ref="#btnVeriAra">
                    <option value="-1">Seç</option>
                </select>
            </div>

            <div class="col">
                <label>Mahalle</label>
                <select id="slcMahalle" class="form-select form-select-sm inputIslem" data-tip="select" data-ref="#btnVeriAra">
                    <option value="-1">Seç</option>
                </select>
            </div>


            <div class="col">
                <label>MT NO</label>
                <input id="txtMtNo" type="text" class="form-control form-control-sm inputIslem" placeholder="MT No" data-tip="enter" data-ref="#btnVeriAra" />
            </div>

            <div class="col">
                <label>Mahalle Kodu</label>
                <input id="txtMahalleKodu" type="text" class="form-control form-control-sm inputIslem" placeholder="Mahalle Kodu" data-tip="enter" data-ref="#btnVeriAra" />
            </div>
        </div>

        <div class="mt-3 d-flex justify-content-between">
            <div><button type="button" class="btnFiltreClear btn btn-secondary btn-sm "><i class="bx bx-square"></i>Temizle</button></div>
            <div class="d-flex gap-1">
                <button id="btnExcel" disabled="disabled" type="button" class="btn btn-success btn-sm" title="Excel"><i class='bx bxs-file-export'></i>Excel</button>
                <button id="btnVeriAra" type="button" class="btnSearch btn btn-warning btn-sm"><i class="bx bx-search"></i><span>Ara</span></button>
            </div>

        </div>
    </div>

    <table class="fixtbl mt-3" cellpadding="0" cellspacing="0" border="0">
        <thead class="tblhead">
            <tr>
                <th>İlçe Adı</th>
                <th>Mahalle Kodu</th>
                <th>Mahalle Adı</th>
                <th>MT NO</th>
                <th>Meclis Karar Tarihi</th>
                <th>Meclis Karar NO</th>
                <th>Birleştiği Mahalle</th>
                <th>Bölündüğü Mahalle</th>
                <th>Cadde Sokak Sayısı</th>
                <th>İsim Veriliş Tarihi</th>
            </tr>
        </thead>
    </table>

    <div class="position-relative">
        <div class="overflow-auto tblbotsty">
            <table class="table fixtbl">
                <tbody id="tblData">
                </tbody>
            </table>
        </div>
        <div class="tblload" hidden="hidden">
            <i class="bx bx-search bx-tada fs-4"></i>Yükleniyor...
        </div>
    </div>



    <div class="modal" id="mdlVeri" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Mahalle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    <button type="button" class="btn btn-full"><i class="ph ph-frame-corners"></i></button>
                </div>
                <div class="modal-body">
                        <div class="row row-cols-3 mb-2">

                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Mahalle Kodu<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <input type="text" class="form-control form-control-sm" value="" id="txtMahalleKodu2" data-validate-hint="Zorunlu Alan!" data-validate-func="required" />
                                </div>
                            </div>

                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">İlçe<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <select id="slcIlce2" class="form-select form-select-sm" data-validate-hint="Zorunlu Alan!" data-validate-func="selectbox">
                                        <option value="-1">Seç</option>
                                    </select>
                                </div>
                            </div>


                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Belediye Adı<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <select id="slcBelediye" class="form-select form-select-sm" data-validate-hint="Zorunlu Alan!" data-validate-func="selectbox">
                                        <option value="-1">Seç</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="row row-cols-2 mb-2">
                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Mahalle Adı<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <input type="text" class="form-control form-control-sm" value="" id="txtMahalleAdi1" />
                                </div>
                            </div>

                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Veriliş Tarihi<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <input type="date" class="form-control form-control-sm" value="" id="txtMahVerTar1" />
                                </div>
                            </div>

                        </div>

                        <div class="mb-3">
                            <div class="lblDiv">
                                <div class="lbll">Mahalle Adı Açıklama<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <textarea id="txtMahalleAdiAciklama1" class="form-control form-control-sm"></textarea>
                            </div>
                        </div>

                        <div class="row row-cols-3 mb-2">
                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Kaydeden<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <input type="text" readonly="readonly" class="form-control form-control-sm" value="" id="txtKaydeden" />
                                </div>
                            </div>
                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Kayıt Tarihi<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <input type="datetime-local" readonly="readonly" class="form-control form-control-sm" value="" id="txtKayitTarihi" />
                                </div>
                            </div>

                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Mahalle Tanıtım No<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <input type="text" class="form-control form-control-sm" value="" id="txtMahalleTanitimNo" />
                                </div>
                            </div>
                        </div>

                        <div class="row row-cols-2 mb-2">
                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Meclis Karar No<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <input type="text" class="form-control form-control-sm" value="" id="txtMeclisKararNo1" />
                                </div>
                            </div>

                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Meclis Karar Tarihi<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <input type="date" class="form-control form-control-sm" value="" id="txtMeclisKararTarihi1" />
                                </div>
                            </div>
                        </div>

                        <div class="row row-cols-2 mb-2">
                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Bölünüdüğü Mahalle<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <input type="text" class="form-control form-control-sm" value="" id="txtBolunmeMahalleAdi1" />
                                </div>
                            </div>

                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Bölünme Tarihi<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <input type="date" class="form-control form-control-sm" value="" id="txtBolunmeMahVerTar1" />
                                </div>
                            </div>
                        </div>

                        <div class="row row-cols-2 mb-2">
                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Birleştiği Mahalle<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <input type="text" class="form-control form-control-sm" value="" id="txtBirlesmeMahalleAdi1" />
                                </div>
                            </div>

                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Birleşme Tarihi<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <input type="date" class="form-control form-control-sm" value="" id="txtBirlesmeMahVerTar1" />
                                </div>
                            </div>
                        </div>

                        <div class="row row-cols-2 mb-2">
                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Mahalle Nufusu<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <input type="text" class="form-control form-control-sm" value="" id="txtMahNufusu" />
                                </div>
                            </div>


                            <div class="col">
                                <div class="lblDiv">
                                    <div class="lbll">Cadde Sokak Sayısı<span class="szr">*</span></div>
                                </div>
                                <div class="ltxt">
                                    <input type="text" class="form-control form-control-sm" value="" id="txtMahCadde1" />
                                </div>
                            </div>
                        </div>

                        <div class="">
                            <div class="lblDiv">
                                <div class="lbll">Tarihçesi<span class="szr">*</span></div>
                            </div>
                            <div class="ltxt">
                                <textarea id="txtMahTArihcesi1" class="form-control form-control-sm"></textarea>
                            </div>
                        </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnInsert" class="btn btn-success">
                        <span class="ph ph-checks me-1"></span>
                        Evrak
                    </button>
                    <button type="button" id="btnInsert" class="btn btn-warning">
                        <span class="ph ph-checks me-1"></span>
                        Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal" id="mdlVeri2" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Mahalle Haritası</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    <button type="button" class="btn btn-full"><i class="ph ph-frame-corners"></i></button>
                </div>
                <div class="modal-body">
                    <div id="map"></div>
                </div>
            </div>
        </div>
    </div>
    @section Scripts {
        <script src="~/js/LeafletJS/leaflet-src.js"></script>
        <script src="~/js/_abs/mahalle.js"></script>
    }
</div>